# Normalize line endings for text files.
* text=auto eol=lf

# Source and project files
*.cs text
*.csx text
*.csproj text
*.sln text
*.slnx text
*.props text
*.targets text
*.ruleset text
*.editorconfig text
*.globalconfig text
nuget.config text
global.json text
Directory.Build.props text
Directory.Build.targets text
Directory.Packages.props text

# Scripts and docs
*.sh text eol=lf
*.ps1 text eol=lf
*.md text
*.txt text
*.yml text
*.yaml text
*.json text
*.xml text

# Keep Windows command files with CRLF when present
*.bat text eol=crlf
*.cmd text eol=crlf

# Large assets tracked with Git LFS.
# NOTE: Use `git lfs install` once per machine.

# Images / textures
*.png filter=lfs diff=lfs merge=lfs -text
*.jpg filter=lfs diff=lfs merge=lfs -text
*.jpeg filter=lfs diff=lfs merge=lfs -text
*.gif filter=lfs diff=lfs merge=lfs -text
